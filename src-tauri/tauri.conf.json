{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WinTaskPro",
  "version": "1.0.0",
  "identifier": "com.wintaskpro.dev",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "py -m http.server 1420 --directory src",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "WinTaskPro — Task Scheduler",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "permissions": [
      "core:default",
      "core:webview:allow-internal-toggle-devtools"
    ]
  }
}