{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WinTaskPro",
  "version": "1.16.2",
  "identifier": "com.nookieai.wintaskpro",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "node devserver.js"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "WinTaskPro \u2014 Task Scheduler",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "maximized": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://api.github.com; frame-ancestors 'none'",
      "dangerousDisableAssetCspModification": ["script-src", "style-src"]
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "publisher": "NookieAI",
    "copyright": "Copyright \u00a9 2026 NookieAI",
    "category": "Utility",
    "shortDescription": "Modern Windows Task Scheduler Manager",
    "longDescription": "WinTaskPro provides a clean, modern interface to manage every scheduled task on your Windows machine \u2014 including hidden system tasks.",
    "windows": {
      "digestAlgorithm": "sha256",
      "certificateThumbprint": null,
      "timestampUrl": "http://timestamp.digicert.com",
      "tsp": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "allowDowngrades": false,
      "nsis": {
        "languages": [
          "English"
        ],
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    }
  }
}
